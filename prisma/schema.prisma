generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String
  company   String
  color     String    @default("#E8630A")
  status    String    @default("prospect")
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id              String           @id @default(cuid())
  title           String
  status          String           @default("pending")
  progress        Int              @default(0)
  startDate       DateTime         @default(now())
  budget          String           @default("")
  shareToken      String           @unique @default(cuid())
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  phases          Phase[]
  emailLogs       EmailLog[]
  notifications   Notification[]
  sharedFiles     SharedFile[]
  dossierMessages DossierMessage[]
}

model Phase {
  id          String    @id @default(cuid())
  title       String
  status      String    @default("pending")
  order       Int
  completedAt DateTime?
  notes       String    @default("")
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
}

model Agent {
  id        String     @id @default(cuid())
  name      String     @unique
  role      String
  script    String
  status    String     @default("idle")
  lastRunAt DateTime?
  runs      AgentRun[]
}

model AgentRun {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id])
  status    String    @default("running")
  input     String    @default("")
  output    String    @default("")
  startedAt DateTime  @default(now())
  endedAt   DateTime?
}

model ActivityLog {
  id        String   @id @default(cuid())
  message   String
  type      String
  agentName String   @default("")
  createdAt DateTime @default(now())
}

model EmailLog {
  id        String   @id @default(cuid())
  message   String
  sentAt    DateTime @default(now())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
}

model SharedFile {
  id          String   @id @default(cuid())
  name        String
  originalName String
  size        Int
  mimeType    String   @default("")
  uploadedAt  DateTime @default(now())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  messages    DossierMessage[]
}

model DossierMessage {
  id        String      @id @default(cuid())
  content   String
  author    String      @default("Studio")
  createdAt DateTime    @default(now())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id])
  fileId    String?
  file      SharedFile? @relation(fields: [fileId], references: [id])
}
